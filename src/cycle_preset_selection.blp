using Gtk 4.0;
using Adw 1;

template $CyclePresetSelection: Adw.Dialog {
    title: _("Choose Cycle Preset");
    content-width: 420;

    Adw.ToolbarView {
        [top]
        Adw.HeaderBar {}

        content: Adw.Clamp {
            Gtk.ListBox presets_list {
                selection-mode: single;
                styles ["boxed-list"]
                
                row-activated => $_on_item_clicked();
            }
        };
    }
}
